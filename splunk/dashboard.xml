<dashboard version="1.1" theme="dark">
  <label>LLM Monitor - Ollama &amp; GPU Dashboard</label>
  <description>Real-time monitoring of Ollama LLM server and GPU resources</description>

  <!-- ▸ OLLAMA STATUS ──────────────────────────────────────────────── -->
  <row groupLabel="OLLAMA STATUS">
    <panel>
      <title>Status</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | eval v=upper(status) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[1]</option>
        <option name="rangeColors">["0x53a051","0xdc4e41"]</option>
      </single>
    </panel>
    <panel>
      <title>Ollama Version</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | table version</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">version</option>
      </single>
    </panel>
    <panel>
      <title>Installed Models</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | table model_count</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">model_count</option>
        <option name="unit">models</option>
      </single>
    </panel>
    <panel>
      <title>Running Models</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | table running_model_count</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">running_model_count</option>
        <option name="unit">models</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[1]</option>
        <option name="rangeColors">["0x444444","0x53a051"]</option>
      </single>
    </panel>
    <panel>
      <title>RAM Offload Active</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | eval v=if(any_offloaded_to_ram="true","YES","NO") | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[1]</option>
        <option name="rangeColors">["0x53a051","0xf8be34"]</option>
      </single>
    </panel>
  </row>

  <!-- ▸ GPU OVERVIEW ───────────────────────────────────────────────── -->
  <row groupLabel="GPU OVERVIEW">
    <panel>
      <title>GPU Count</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | table gpu_count</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">gpu_count</option>
        <option name="unit">GPUs</option>
      </single>
    </panel>
    <panel>
      <title>VRAM Usage %</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | eval v=round(used_vram_mb/total_vram_mb*100,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[81,100]</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
      </single>
    </panel>
    <panel>
      <title>Used VRAM</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | eval v=round(used_vram_mb/1024,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">GB</option>
      </single>
    </panel>
    <panel>
      <title>Free VRAM</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | eval v=round(free_vram_mb/1024,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">GB</option>
      </single>
    </panel>
    <panel>
      <title>Total VRAM</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | eval v=round(total_vram_mb/1024,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">GB</option>
      </single>
    </panel>
    <panel>
      <title>GPU Utilization</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | spath output=g path="gpus{}" | mvexpand g | spath input=g | stats avg(gpu_utilization_pct) as v | eval v=round(v,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">%</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[50,90]</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
      </single>
    </panel>
    <panel>
      <title>GPU Temperature</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | spath output=g path="gpus{}" | mvexpand g | spath input=g | stats avg(temperature_c) as v | eval v=round(v,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">°C</option>
        <option name="colorMode">block</option>
        <option name="useColors">1</option>
        <option name="rangeValues">[70,85]</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
      </single>
    </panel>
    <panel>
      <title>Power Draw</title>
      <single>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | spath output=g path="gpus{}" | mvexpand g | spath input=g | stats avg(power_draw_w) as v | eval v=round(v,1) | table v</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="field">v</option>
        <option name="unit">W</option>
      </single>
    </panel>
  </row>

  <!-- ▸ GPU TIME-SERIES ────────────────────────────────────────────── -->
  <row groupLabel="GPU METRICS — HISTORY">
    <panel>
      <title>GPU Utilization (%) — Over Time</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=gpu | spath output=g path="gpus{}" | mvexpand g | spath input=g | timechart avg(gpu_utilization_pct) by name span=1m</query>
          <earliest>-1h</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.seriesColors">["0x00b4d8","0xf8be34","0x53a051"]</option>
        <option name="charting.axisTitleY.text">Utilization (%)</option>
        <option name="charting.axisY.maximumNumber">100</option>
        <option name="charting.axisY.minimumNumber">0</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
    <panel>
      <title>GPU Temperature (°C) — Over Time</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=gpu | spath output=g path="gpus{}" | mvexpand g | spath input=g | timechart avg(temperature_c) by name span=1m</query>
          <earliest>-1h</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.seriesColors">["0xf8be34","0xdc4e41","0x00b4d8"]</option>
        <option name="charting.axisTitleY.text">Temperature (°C)</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>VRAM Usage (GB) — Over Time</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=gpu | eval used=round(used_vram_mb/1024,2) | eval total=round(total_vram_mb/1024,2) | timechart avg(used) as "Used VRAM (GB)", avg(total) as "Total VRAM (GB)" span=1m</query>
          <earliest>-1h</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.seriesColors">["0x0096c7","0x1a4a6e"]</option>
        <option name="charting.axisTitleY.text">VRAM (GB)</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
    <panel>
      <title>GPU Power Draw (W) — Over Time</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=gpu | spath output=g path="gpus{}" | mvexpand g | spath input=g | timechart avg(power_draw_w) by name span=1m</query>
          <earliest>-1h</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.seriesColors">["0xf8be34","0xdc4e41"]</option>
        <option name="charting.axisTitleY.text">Power (W)</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
  </row>

  <!-- ▸ PER-MODEL GPU METRICS ─────────────────────────────────────── -->
  <row groupLabel="PER-MODEL GPU METRICS">
    <panel>
      <title>VRAM Usage by Running Model (GB)</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=ollama running_model_count>0 | head 20 | spath output=rm path="running_models{}" | mvexpand rm | spath input=rm | chart avg(size_vram_gb) as "VRAM (GB)", avg(size_ram_gb) as "RAM Offload (GB)" by name</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.seriesColors">["0x0096c7","0xf8be34"]</option>
        <option name="charting.axisTitleX.text">Model</option>
        <option name="charting.axisTitleY.text">Memory (GB)</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
      </chart>
    </panel>
    <panel>
      <title>VRAM Usage % — Over Time</title>
      <chart>
        <search>
          <query>index=llm_monitor metric_type=gpu | eval vram_pct=round(used_vram_mb/total_vram_mb*100,1) | timechart avg(vram_pct) as "VRAM Usage (%)" span=1m</query>
          <earliest>-1h</earliest><latest>now</latest>
        </search>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.seriesColors">["0x53a051"]</option>
        <option name="charting.axisTitleY.text">VRAM Usage (%)</option>
        <option name="charting.axisY.maximumNumber">100</option>
        <option name="charting.axisY.minimumNumber">0</option>
        <option name="charting.legend.placement">bottom</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>
  </row>

  <!-- ▸ DETAIL TABLES ──────────────────────────────────────────────── -->
  <row groupLabel="DETAIL TABLES">
    <panel>
      <title>Current GPU Status</title>
      <table>
        <search>
          <query>index=llm_monitor metric_type=gpu | head 1 | spath output=g path="gpus{}" | mvexpand g | spath input=g | eval vram_label=memory_used_mb." / ".memory_total_mb." MB (".round(memory_used_mb/memory_total_mb*100,1)."%)" | table name, vendor, temperature_c, gpu_utilization_pct, vram_label, power_draw_w, clock_graphics_mhz, performance_state | rename name AS "GPU Name", vendor AS Vendor, temperature_c AS "Temp °C", gpu_utilization_pct AS "Util %", vram_label AS "VRAM Used", power_draw_w AS "Power W", clock_graphics_mhz AS "Clock MHz", performance_state AS "P-State"</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="wrap">true</option>
        <option name="rowNumbers">false</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Running Models — VRAM + RAM Offload</title>
      <table>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | spath output=rm path="running_models{}" | mvexpand rm | spath input=rm | eval ram_offload=if(offloaded_to_ram="true" OR offloaded_to_ram="True","YES  "+size_ram_gb+" GB","—") | table name, size_vram_gb, size_ram_gb, size_total_gb, ram_offload, expires_at | rename name AS Model, size_vram_gb AS "VRAM (GB)", size_ram_gb AS "RAM (GB)", size_total_gb AS "Total (GB)", ram_offload AS "RAM Offload", expires_at AS "Expires At"</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="wrap">true</option>
        <option name="rowNumbers">false</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Installed Models</title>
      <table>
        <search>
          <query>index=llm_monitor metric_type=ollama | head 1 | spath output=m path="models{}" | mvexpand m | spath input=m | table name, family, parameter_size, quantization, size_gb, modified_at | rename name AS Model, family AS Family, parameter_size AS Parameters, quantization AS Quantization, size_gb AS "Size (GB)", modified_at AS "Last Modified"</query>
          <earliest>-5m</earliest><latest>now</latest>
        </search>
        <option name="wrap">true</option>
        <option name="rowNumbers">true</option>
      </table>
    </panel>
  </row>

</dashboard>
