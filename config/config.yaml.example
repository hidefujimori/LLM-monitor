splunk:
  hec_url: "https://172.26.10.100:8088/services/collector/event"
  hec_token: "YOUR-HEC-TOKEN-HERE"
  index: "llm_monitor"
  source: "llm-monitor"
  sourcetype: "llm:metrics"
  verify_ssl: false

ollama:
  base_url: "http://172.26.1.20:11434"
  timeout: 10

collection:
  interval_seconds: 60
  gpu_enabled: true

logging:
  level: "INFO"
  file: "logs/llm-monitor.log"

retry_queue:
  dir: "queue"
  max_size_mb: 300
